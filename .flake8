[flake8]
# Match black's line length
max-line-length = 200

# Ignore rules that conflict with black formatting
# E203: whitespace before ':' (black formats slice notation differently)
# W503: line break before binary operator (black prefers this style)
extend-ignore = E203, W503

# Only lint the aiecs package
per-file-ignores =
    # Allow unused imports in __init__.py (re-exports)
    aiecs/__init__.py: F401
    aiecs/*/__init__.py: F401

exclude =
    .git,
    .mypy_cache,
    .venv,
    __pycache__,
    build,
    dist,
    *.egg-info

